---
layout: base.njk
title: Home
description: Professional countertop fabrication and installation services. Expert granite, quartz, and marble countertops for kitchens and bathrooms in your area.
---

<!-- Hero Section -->
<section class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">Premium fabrication & installation</div>
      <h1 class="hero-title">Custom Countertops Built to Last</h1>
      <p class="hero-subtitle">Transform your space with expertly crafted granite, quartz, and marble countertops. Quality craftsmanship, honest pricing, professional installation.</p>
      
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">Get a Free Quote</a>
        <a href="#services" class="btn-outline">View Services</a>
      </div>
      
      <div class="hero-features">
        <span class="hero-feature-tag"><span class="dot"></span> Locally Owned</span>
        <span class="hero-feature-tag"><span class="dot"></span> Transparent Pricing</span>
        <span class="hero-feature-tag"><span class="dot"></span> Professional Installation</span>
        <span class="hero-feature-tag"><span class="dot"></span> Free Estimates</span>
      </div>
    </div>
    
    <div class="hero-visual">
      <div class="hero-image-wrapper">
        <picture>
          <source srcset="/assets/images/hero/hero-featured.webp" type="image/webp">
          <img src="/assets/images/hero/hero-featured.jpg" alt="Marble countertop with wine cooler installation" width="800" height="600" loading="eager">
        </picture>
      </div>
      
      <div class="hero-info-cards">
        <div class="hero-info-card">
          <div class="hero-info-card-label">Why Homeowners Choose Us</div>
          <p>Clean installs, strong materials, honest work.</p>
        </div>
        <div class="hero-info-card">
          <div class="hero-info-card-label">Now Booking</div>
          <p>Kitchens, bathrooms, vanities, and more.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Services Section -->
<section id="services" class="section services">
  <div class="container">
    <div class="section-header section-header-centered">
      <span class="section-label">Services</span>
      <h2 class="section-title">Quality Work from Fabrication to Final Install</h2>
      <p class="section-subtitle">We specialize in custom countertop fabrication and installation with a commitment to quality and customer satisfaction.</p>
    </div>
    
    <div class="services-grid">
      {% for service in site.services %}
      <div class="service-card">
        <div class="service-icon">{{ service.icon }}</div>
        <h3 class="service-title">{{ service.name }}</h3>
        <p class="service-description">{{ service.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Gallery Section -->
<section id="gallery" class="section gallery">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Gallery</span>
      <h2 class="section-title">Our Work</h2>
    </div>
    
    <div class="gallery-grid">
      <div class="gallery-item">
        <picture>
          <source srcset="/assets/images/gallery/marble-shower-enclosure.webp" type="image/webp">
          <img src="/assets/images/gallery/marble-shower-enclosure.jpg" alt="Custom marble shower enclosure with glass doors" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Marble Shower Enclosure</p>
        </div>
      </div>
      
      <div class="gallery-item">
        <picture>
          <source srcset="/assets/images/gallery/commercial-bar-counter.webp" type="image/webp">
          <img src="/assets/images/gallery/commercial-bar-counter.jpg" alt="Commercial bar counter with LED lighting and quartz surface" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Commercial Bar Counter</p>
        </div>
      </div>
      
      <div class="gallery-item">
        <picture>
          <source srcset="/assets/images/gallery/luxury-commercial-interior.webp" type="image/webp">
          <img src="/assets/images/gallery/luxury-commercial-interior.jpg" alt="Luxury commercial interior with black granite and gold accents" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Luxury Commercial Interior</p>
        </div>
      </div>
      
      <div class="gallery-item">
        <picture>
          <source srcset="/assets/images/gallery/quartz-countertop-kitchen.webp" type="image/webp">
          <img src="/assets/images/gallery/quartz-countertop-kitchen.jpg" alt="Blue quartz kitchen countertop with stainless steel sink" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Quartz Kitchen Countertop</p>
        </div>
      </div>
      
      <div class="gallery-item">
        <picture>
          <source srcset="/assets/images/gallery/marble-wetbar-countertop.webp" type="image/webp">
          <img src="/assets/images/gallery/marble-wetbar-countertop.jpg" alt="Marble wet bar countertop with wine cooler" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Marble Wet Bar Countertop</p>
        </div>
      </div>
      
      <div class="gallery-item gallery-item-edge-profiles">
        <picture>
          <source srcset="/assets/images/gallery/edge-profiles-reference.webp" type="image/webp">
          <img src="/assets/images/gallery/edge-profiles-reference.jpg" alt="Available countertop edge profile options including round, bevel, ogee, bullnose, and waterfall" width="600" height="450" loading="lazy">
        </picture>
        <div class="gallery-item-overlay">
          <p>Edge Profile Options</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Section -->
<section id="contact" class="section contact">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Contact</span>
      <h2 class="section-title">Get your free quote</h2>
    </div>
    
    <div class="contact-form">
      <form action="#" method="POST">
        <div class="form-row">
          <div class="form-group">
            <input type="text" id="name" name="name" placeholder="Name" required>
          </div>
          <div class="form-group">
            <input type="tel" id="phone" name="phone" placeholder="Phone">
          </div>
        </div>
        <div class="form-group">
          <input type="email" id="email" name="email" placeholder="Email" required>
        </div>
        <div class="form-group">
          <textarea id="message" name="message" placeholder="Tell us about your project" required></textarea>
        </div>
        <button type="submit" class="form-submit">Send Message</button>
      </form>
    </div>
    
    <div class="contact-details">
      <div class="contact-info-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        <a href="tel:{{ site.business.phone }}">{{ site.business.phone }}</a>
      </div>
      <div class="contact-info-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <a href="mailto:{{ site.business.email }}">{{ site.business.email }}</a>
      </div>
      <div class="contact-info-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{{ site.business.address.street }}, {{ site.business.address.city }}, {{ site.business.address.state }} {{ site.business.address.zip }}</span>
      </div>
    </div>
  </div>
</section>
